{% if operation.request_body.content_rows %}
{{ table(["Content Type", "Schema", "Required Fields"], operation.request_body.content_rows) }}
{% else %}
{{ bullet_list(["Content: " ~ operation.request_body.content]) }}
{% endif %}
{% for example in operation.request_body.examples %}
{{ shared.detail_code_block("Request Example: " ~ example.content_type, "json", example.body) }}
{% endfor %}
{% endif %}
{% if operation.response_rows %}
{{ shared.detail_table("Responses", ["Code", "Description", "Content Types", "Schemas"], operation.response_rows) }}
{% endif %}

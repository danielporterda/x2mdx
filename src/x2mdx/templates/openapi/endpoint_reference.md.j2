{% import "shared/macros.md.j2" as shared %}
{% for path_group in path_groups %}
{{ anchor(path_group.anchor_id) }}

{{ heading(3, path_group.header) }}
{% if path_group.methods | length > 1 %}
{{ bullet_list(["Methods: " ~ (path_group.methods | join(", "))]) }}
{% endif %}
{% for operation in path_group.operations %}
{{ anchor(operation.anchor_id) }}
{% if path_group.methods | length == 1 %}
{{ bullet_list(["Method: " ~ operation.method]) }}
{% else %}
{{ shared.detail_label(operation.method) }}
{% endif %}
{% if operation.bullet_items %}
{{ bullet_list(operation.bullet_items) }}
{% endif %}
{% if operation.parameter_rows %}
{{ shared.detail_table("Parameters", ["Name", "In", "Required", "Schema", "Description"], operation.parameter_rows) }}
{% endif %}
{% if operation.request_body %}
{{ shared.detail_label("Request Body") }}


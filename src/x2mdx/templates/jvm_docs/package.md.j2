{% import "shared/macros.md.j2" as shared %}
{% call shared.standard_reference_layout(toc_rows=type_reference_rows, include_version_summary=False) %}
{% for entry in package_entries %}

{{ anchor(entry.anchor) }}

{{ heading(3, entry.heading) }}

{{ bullet_list(entry.lifecycle_items) }}
{% if entry.upstream != "-" %}
{{ paragraph("Upstream docs: " ~ entry.upstream) }}
{% endif %}
{% if entry.signature %}
{{ paragraph("**Signature**") }}

{{ code_block("text", entry.signature) }}
{% endif %}
{% if entry.summary %}
{{ paragraph("**Summary**") }}

{{ paragraph(entry.summary) }}
{% endif %}
{{ paragraph("**Members**") }}
{% if entry.member_rows %}
{{ table(["Docs", "Member", "Introduced", "Deprecated", "Removed"], entry.member_rows) }}
{% else %}
{{ paragraph("No members found for this type in the configured artifacts.") }}
{% endif %}
{% endfor %}
{% endcall %}

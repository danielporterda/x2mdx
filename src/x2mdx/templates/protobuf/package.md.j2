{% import "shared/macros.md.j2" as shared %}
{{ heading(1, package_title) }}

{{ paragraph("[Back to Canton Protobuf History](" ~ overview_link ~ ")") }}

{{ shared.bullet_section("Snapshot", snapshot_items) }}
{% if source_file_rows %}

{{ heading(2, "Source Files") }}

{{ table(["File", "Services", "Messages", "Enums", "Source"], source_file_rows) }}
{% endif %}
{% if services %}

{{ heading(2, "Services") }}

{{ table(["Service", "Lifecycle", "Endpoints", "Source", "Description"], service_rows) }}
{% for service in services %}

{{ anchor(service.anchor) }}
{{ heading(3, service.heading) }}

{{ bullet_list(service.summary_items) }}

{{ paragraph(service.description) }}

{{ table(["Endpoint", "Lifecycle", "Replaces", "Introduced", "Last Changed", "Removed", "Request", "Response", "Source"], service.endpoint_rows) }}
{% for endpoint in service.endpoint_details %}

{{ anchor(endpoint.anchor) }}
{{ shared.detail_label("Endpoint `" ~ endpoint.title ~ "`") }}

{{ bullet_list(endpoint.summary_items) }}

{{ shared.detail_code_block("Signature", "protobuf", endpoint.signature) }}

{{ paragraph(endpoint.description) }}

{{ shared.detail_label("History") }}

{{ endpoint.history_table }}

{{ shared.detail_bullet_list("Request Type", [endpoint.request_type]) }}

{{ shared.detail_bullet_list("Response Type", [endpoint.response_type]) }}
{% endfor %}
{% endfor %}
{% endif %}
{% if type_reference_blocks %}

{{ heading(2, "Type Reference") }}
{% for block in type_reference_blocks %}

{{ block }}
{% endfor %}
{% endif %}
